# =============================================================================
# Supabase (PostgreSQL) — Project Settings → Database
# =============================================================================
# 1) Open "Connection string" → tab "URI".
# 2) DATABASE_URL: switch method to "Transaction pooler" (port 6543). Copy URI.
#    Append if missing: ?pgbouncer=true
# 3) DIRECT_URL: use "Session mode" or the "Direct connection" URI (port 5432).
#    Migrations and prisma migrate deploy use DIRECT_URL only.
#
# Easy mode (OK for local dev): paste the same Supabase "Direct connection" URI into BOTH variables.
# Recommended on Vercel: DATABASE_URL = Transaction pooler (:6543, pgbouncer=true), DIRECT_URL = Direct (:5432).
#
# Examples (replace with your dashboard strings):
# DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.supabase.co:5432/postgres"

DATABASE_URL=""
DIRECT_URL=""

# =============================================================================
# Auth & encryption (generate long random strings, 32+ chars recommended)
# =============================================================================
AUTH_SECRET=""
TOKEN_ENCRYPTION_KEY=""

# =============================================================================
# Plaid — https://dashboard.plaid.com/team/keys
# =============================================================================
PLAID_CLIENT_ID=""
PLAID_SECRET=""
PLAID_ENV="sandbox"

# =============================================================================
# App URL (browser + Plaid redirects). Production: https://your-deployment.vercel.app
# =============================================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# =============================================================================
# Optional — only if you add Supabase client features (Storage, Realtime, etc.)
# BillFlow core uses Prisma only; these are not read by the app today.
# =============================================================================
# NEXT_PUBLIC_SUPABASE_URL="https://PROJECT_REF.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
# SUPABASE_SERVICE_ROLE_KEY="eyJ..."
