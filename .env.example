# PostgreSQL (Neon, Supabase, or local). Required for production (e.g. Vercel).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"

AUTH_SECRET="generate-a-long-random-string-at-least-16-chars"
TOKEN_ENCRYPTION_KEY="another-long-secret-for-encrypting-plaid-tokens"

PLAID_CLIENT_ID="from Plaid dashboard"
PLAID_SECRET="sandbox or production secret"
PLAID_ENV="sandbox"

# Production: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL="http://localhost:3000"
